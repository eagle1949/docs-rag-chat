# Flask基础配置 / Flask Basic Configuration
FLASK_DEBUG=1
FLASK_ENV=development

# WTF配置 / WTF Configuration
WTF_CSRF_ENABLED=False

# SQLAlchemy数据库配置 / SQLAlchemy Database Configuration
SQLALCHEMY_DATABASE_URI=postgresql://postgres:postgres@127.0.0.1:5432/llmops?client_encoding=utf8
SQLALCHEMY_POOL_SIZE=30
SQLALCHEMY_POOL_RECYCLE=3600
SQLALCHEMY_ECHO=True

# OpenAI服务提供者 / OpenAI Service Provider
# 请替换为您的实际API密钥 / Replace with your actual API key
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1

# 可选: 使用其他兼容OpenAI的API / Optional: Use other OpenAI-compatible APIs
# OPENAI_API_BASE=https://api.moonshot.cn/v1
# OPENAI_API_BASE=https://api.siliconflow.cn/v1

# HuggingFace配置 (可选) / HuggingFace Configuration (Optional)
HUGGINGFACEHUB_API_TOKEN=your_huggingface_token_here

# 百度千帆服务提供者 (可选) / Baidu Qianfan Service Provider (Optional)
QIANFAN_ACCESS_KEY=your_qianfan_access_key_here
QIANFAN_SECRET_KEY=your_qianfan_secret_key_here

# LangSmith配置 (可选，用于追踪) / LangSmith Configuration (Optional, for tracing)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=your_project_name_here

# Pinecone配置 (可选) / Pinecone Configuration (Optional)
PINECONE_API_KEY=your_pinecone_api_key_here

# Serper API - Google搜索 (可选) / Serper API - Google Search (Optional)
# 获取API密钥: https://serper.dev/ / Get API key at: https://serper.dev/
SERPER_API_KEY=your_serper_api_key_here

# 高德地图API (可选) / Amap API (Optional)
GAODE_API_KEY=your_amap_api_key_here

# 阿里云通义千问 (可选) / Alibaba Cloud Tongyi Qianwen (Optional)
DASHSCOPE_API_KEY=your_dashscope_api_key_here
