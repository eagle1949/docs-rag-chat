{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Flask API",
            "type": "debugpy",
            "request": "launch",
            "module": "app.http.app",
            "env": {
                "FLASK_ENV": "development",
                "FLASK_DEBUG": "1",
                "PYTHONPATH": "${workspaceFolder}"
            },
            "envFile": "${workspaceFolder}/.env",
            "console": "integratedTerminal",
            "justMyCode": true
        }
    ]
}
